# ============================================================
# YordamchiAI — Environment Variables
#
# LOCAL DEVELOPMENT:
#   cp .env.example .env
#   Fill in your values. Never commit .env to git.
#
# VERCEL PRODUCTION:
#   Add every variable below to:
#   Vercel Dashboard → Project → Settings → Environment Variables
#   Set Environments: Production, Preview, Development (as needed)
#   Then redeploy.
# ============================================================

# ─── REQUIRED — App will throw and show white screen without these ────────────

# Supabase Project URL
# Source: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase Anonymous (public) API Key
# Source: Supabase Dashboard → Project Settings → API → anon / public
# This key is safe to expose in the browser.
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── OPTIONAL — Error monitoring (recommended for production) ─────────────────

# Sentry DSN — enables error monitoring. App works fine without it (no-op).
# Source: sentry.io → Project → Settings → Client Keys (DSN)
# Safe to expose in the browser (send-only). Events are sent from PRODUCTION
# builds only; local dev stays console-only.
# On Vercel: add VITE_SENTRY_DSN to Project → Settings → Environment Variables.
# VITE_SENTRY_DSN=https://<key>@o<org>.ingest.<region>.sentry.io/<project>

# ─── OPTIONAL — Has a safe default, app works without it ─────────────────────

# Legacy REST API base URL (unused in current Supabase implementation)
# Default: http://localhost:3000/api
# VITE_API_URL=https://your-api-server.com/api

# ─── OPTIONAL — Click / Payme payment gateway (frontend merchant IDs) ────────
#
# Public merchant identifiers used to build the checkout redirect URL.
# Until these are set, the Click/Payme buttons stay hidden and orgs use the
# manual receipt-upload flow. Safe to expose in the browser.
#   Source (Click):  merchant cabinet → your service → Service ID / Merchant ID
#   Source (Payme):  merchant (Paycom) cabinet → cashbox → Merchant ID
# VITE_CLICK_SERVICE_ID=your-click-service-id
# VITE_CLICK_MERCHANT_ID=your-click-merchant-id
# VITE_PAYME_MERCHANT_ID=your-payme-merchant-id

# ─── NOT VITE_ — Supabase Edge Function secrets (server-side only) ───────────
#
# These are NOT frontend variables. They are never set in .env or Vercel
# Environment Variables for the frontend. They are set via Supabase CLI:
#
#   supabase secrets set GEMINI_API_KEY=your_gemini_key
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
#
# Payment gateway callback secrets (server-side, for the edge functions
# click-callback / payme-callback). Set once the merchant keys arrive:
#   supabase secrets set CLICK_SERVICE_ID=... CLICK_SECRET_KEY=...
#   supabase secrets set PAYME_KEY=...
# Then deploy the functions:
#   supabase functions deploy click-callback --no-verify-jwt
#   supabase functions deploy payme-callback --no-verify-jwt
# Register these callback URLs in the Click / Payme merchant cabinets:
#   https://<project-ref>.supabase.co/functions/v1/click-callback
#   https://<project-ref>.supabase.co/functions/v1/payme-callback
#
# Edge Function auto-variables (injected by Supabase, do not set manually):
#   SUPABASE_URL
#   SUPABASE_ANON_KEY
#   SUPABASE_SERVICE_ROLE_KEY
#   SUPABASE_DB_URL
